# Database (Docker PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marketing_cms"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-min-32-chars-long"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# App
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Minimax AI Chat
MINIMAX_API_KEY="your-minimax-api-key"
NEXT_PUBLIC_ENABLE_CHAT="true"

# GitHub Integration
GITHUB_USERNAME="your-github-username"
# Optional: GITHUB_TOKEN="ghp_..." (for higher API rate limits)

# Dev.to Integration
DEV_TO_USERNAME="your-devto-username"